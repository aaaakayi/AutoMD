source leaprc.protein.ff14SB
source leaprc.gaff2
source leaprc.water.tip3p

# Load protein
prot = loadpdb ./output/prepared/1IEP_protein_only.pdb

# Load ligand parameters and coordinates
loadamberparams ./output/ligand/lig.frcmod
LIG = loadmol2 ./output/ligand/lig_dedup3.mol2

# Combine protein and ligand
complex = combine {prot LIG}

# Solvate
solvateBox complex TIP3PBOX 10.0

# Add ions (neutralize)
addions complex Na+ 0
addions complex Cl- 0

# Save
saveamberparm complex ./output/md/complex_with_lig.prmtop ./output/md/complex_with_lig.inpcrd
quit
